{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "PowerShell(npm run build *)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(git diff *)",
      "PowerShell(git status *)",
      "PowerShell(npx playwright *)",
      "PowerShell(git stash *)",
      "Bash(npm run build *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(npx playwright *)",
      "Bash(git stash *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/normalize-shell.sh"
          }
        ]
      }
    ]
  }
}
