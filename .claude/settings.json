{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "PowerShell(npm run build *)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(git diff *)",
      "PowerShell(git status *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/normalize-shell.sh"
          }
        ]
      }
    ]
  }
}
